<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Common style for all Sliders -->
    <style name="AppSliderStyle" parent="Widget.MaterialComponents.Slider">
        <item name="thumbHeight">10dp</item>
        <item name="thumbWidth">4dp</item>
        <item name="thumbTrackGapSize">0dp</item>
        <item name="trackCornerSize">2dp</item>
        <item name="trackHeight">5dp</item>
        <item name="trackColor">#9E9E9E</item>
    </style>


    <!-- Custom style for your custom setting toolbar layout -->
    <style name="ToolbarStyle">
        <item name="android:layout_height">50dp</item>
        <item name="android:background">?attr/colorPrimary</item>
        <item name="android:paddingEnd">2dp</item>
        <item name="titleTextColor">@color/white</item>
        <item name="titleTextSize">20sp</item>
        <item name="titleFontStyle">bold</item>

    </style>

</resources>