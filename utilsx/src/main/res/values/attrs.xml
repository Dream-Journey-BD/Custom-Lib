<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--Color Picker-->
    <declare-styleable name="ColorPickerAttr">
        <attr name="setInitialColor" format="color" />"
        <attr name="setButtonTextColor" format="color" />
        <attr name="enableAlpha" format="boolean" />
        <attr name="showButton" format="boolean" />
    </declare-styleable>

    <!--Image Color Picker-->
    <declare-styleable name="ImageColorPickerAttr">
        <attr name="setImageSrc" format="reference" />"
        <attr name="setSelectorIcon" format="reference" />"
        <attr name="showFlag" format="boolean" />"
    </declare-styleable>

    <!--Custom WheelView For Value select-->
    <declare-styleable name="WheelView">
        <attr name="wvCenterTextColor" format="color|reference" />
        <attr name="wvNormalLineColor" format="color|reference" />
        <attr name="wvCenterLineColor" format="color|reference" />
        <attr name="wvNormalTextColor" format="color|reference" />
        <attr name="wvAffixColorColor" format="color|reference" />
        <attr name="wvCursorColor" format="color|reference" />
        <attr name="wvLineSpaceFactor" format="float" />
        <attr name="wvLineHeightRatio" format="float" />
        <attr name="wvCursorSize" format="dimension" />
        <attr name="wvNormalTextSize" format="dimension" />
        <attr name="wvCenterTextSize" format="dimension" />
        <attr name="wvSuffixText" format="string|reference" />
        <attr name="wvPrefixText" format="string|reference" />
        <attr name="wvShowLine" format="boolean" />
    </declare-styleable>

    <!--Custom ToolBar-->
    <declare-styleable name="CustomToolBar">
        <attr name="navigationIconTint" format="color" />
        <attr name="titleTextSize" format="dimension" />
        <attr name="titleFontStyle">
            <flag name="normal" value="0" />
            <flag name="bold" value="1" />
            <flag name="italic" value="2" />
            <flag name="bold_italic" value="3" />
        </attr>
        <attr name="overflowMenuIcon" format="reference" />
        <attr name="overflowMenuIconTint" format="color" />
    </declare-styleable>

    <!--Custom Signature Pad-->
    <declare-styleable name="SignaturePad">
        <attr name="penMinWidth" format="dimension" />
        <attr name="penMaxWidth" format="dimension" />
        <attr name="penColor" format="color" />
        <attr name="velocityFilterWeight" format="float" />
        <attr name="clearOnDoubleClick" format="boolean" />
    </declare-styleable>

    <!--Crop Image But Need To Remove Something-->
    <declare-styleable name="CropImageView">
        <attr name="cropGuidelines">
            <enum name="off" value="0" />
            <enum name="onTouch" value="1" />
            <enum name="on" value="2" />
        </attr>
        <attr name="cropScaleType">
            <enum name="fitCenter" value="0" />
            <enum name="center" value="1" />
            <enum name="centerCrop" value="2" />
            <enum name="centerInside" value="3" />
        </attr>
        <attr name="cropShape">
            <enum name="rectangle" value="0" />
            <enum name="oval" value="1" />
        </attr>
        <attr name="cropAutoZoomEnabled" format="boolean" />
        <attr name="cropMaxZoom" format="integer" />
        <attr name="cropMultiTouchEnabled" format="boolean" />
        <attr name="cropFixAspectRatio" format="boolean" />
        <attr name="cropAspectRatioX" format="integer" />
        <attr name="cropAspectRatioY" format="integer" />
        <attr name="cropInitialCropWindowPaddingRatio" format="float" />
        <attr name="cropBorderLineThickness" format="dimension" />
        <attr name="cropBorderLineColor" format="color" />
        <attr name="cropBorderCornerThickness" format="dimension" />
        <attr name="cropBorderCornerOffset" format="dimension" />
        <attr name="cropBorderCornerLength" format="dimension" />
        <attr name="cropBorderCornerColor" format="color" />
        <attr name="cropGuidelinesThickness" format="dimension" />
        <attr name="cropGuidelinesColor" format="color" />
        <attr name="cropBackgroundColor" format="color" />
        <attr name="cropSnapRadius" format="dimension" />
        <attr name="cropTouchRadius" format="dimension" />
        <attr name="cropSaveBitmapToInstanceState" format="boolean" />
        <attr name="cropShowCropOverlay" format="boolean" />
        <attr name="cropShowProgressBar" format="boolean" />
        <attr name="cropMinCropWindowWidth" format="dimension" />
        <attr name="cropMinCropWindowHeight" format="dimension" />
        <attr name="cropMinCropResultWidthPX" format="float" />
        <attr name="cropMinCropResultHeightPX" format="float" />
        <attr name="cropMaxCropResultWidthPX" format="float" />
        <attr name="cropMaxCropResultHeightPX" format="float" />
        <attr name="cropFlipHorizontally" format="boolean" />
        <attr name="cropFlipVertically" format="boolean" />
    </declare-styleable>


</resources>